<?php

declare(strict_types=1);

namespace {{ namespace }};

use App\Http\Controllers\Api\{{ model }}\{{ model }}ShowController;
use {{ namespacedModel }};
use App\Models\User;
use Database\Factories\{{ model }}Factory;
use Database\Factories\UserFactory;
use Illuminate\Foundation\Testing\RefreshDatabase;
use Thinkycz\LaravelCore\Support\Resolver;
use Thinkycz\LaravelCore\Support\Typer;
use Tests\TestCase;

class {{ model }}ShowControllerTest extends TestCase
{
    use RefreshDatabase;

    public function test_show_{{ table }}(): void
    {
        $auth = Typer::assertInstance(UserFactory::new()->createOne(), User::class);

        $model = Typer::assertInstance(
            {{ model }}Factory::new()
                ->for($auth)
                ->createOne(),
            {{ model }}::class,
        );

        $query = [
            'id' => $model->getKey(),
        ];

        $response = $this->be($auth)->get(Resolver::resolveUrlGenerator()->action({{ model }}ShowController::class, $query));

        $response->assertOk();
    }
}
