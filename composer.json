{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "thinkycz/laravel-inertia-stack",
    "type": "project",
    "description": "Laravel Inertia Vue boilerplate",
    "keywords": [
        "thinkycz",
        "laravel",
        "inertia",
        "vue",
        "boilerplate"
    ],
    "authors": [
        {
            "name": "Thinkycz",
            "email": "me@thinky.cz"
        }
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.3.0",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "thinkycz/laravel-core": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^12.0",
        "spaze/phpstan-disallowed-calls": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/thinkycz/laravel-core"
        }
    ],
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-install-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php -r \"file_exists('stubs') || (PHP_OS_FAMILY === 'Windows' ? exec('mklink /J '.escapeshellarg('stubs').' '.escapeshellarg('packages/thinkycz/laravel-core/stubs')) : symlink('packages/thinkycz/laravel-core/stubs', 'stubs'));\""
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php -r \"file_exists('stubs') || (PHP_OS_FAMILY === 'Windows' ? exec('mklink /J '.escapeshellarg('stubs').' '.escapeshellarg('packages/thinkycz/laravel-core/stubs')) : symlink('packages/thinkycz/laravel-core/stubs', 'stubs'));\""
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
